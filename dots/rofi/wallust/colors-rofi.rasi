alternate-normal-foreground: #C8D7E3;
alternate-urgent-background: #121019;
alternate-urgent-foreground: #C8D7E3;

selected-active-background: #1933BC;
selected-active-foreground: #121019;
selected-normal-background: #1933BC;
selected-normal-foreground: #121019;
