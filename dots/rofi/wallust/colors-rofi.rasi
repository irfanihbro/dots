 /* wallust template - colors-rofi */

* {
active-background: #1933BC;
active-foreground: #C8D7E3;
normal-background: #121019;
normal-foreground: #C8D7E3;
urgent-background: #426494;
urgent-foreground: #C8D7E3;

alternate-active-background: #11256A;
alternate-active-foreground: #C8D7E3;
